# Copy to `.env` and fill in only what you need. Everything has a working default.

# --- Audit / decision store (the Java service) ---
AUDIT_BASE_URL=http://localhost:8080
AUDIT_ENABLED=true
# Must match Java SDE_API_KEY when auth is enabled
SDE_API_KEY=

# --- Engine API auth (optional — protects /decide, webhooks, /admin) ---
ENGINE_API_KEY=

# --- Zendesk webhook signing (from Zendesk Admin → Webhooks → Signing secret) ---
ZENDESK_WEBHOOK_SECRET=

# --- LLM reasoning layer ---
# heuristic (default, no key) | openai | anthropic
LLM_PROVIDER=heuristic
# LLM_MODEL=gpt-4o-mini
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# --- Customer context ---
# mock (default) | stripe
CONTEXT_PROVIDER=mock
# STRIPE_API_KEY=sk_live_...

# --- Policy rules ---
# POLICIES_PATH=config/policies.json

# --- Retry settings for external calls ---
RETRY_ATTEMPTS=3
RETRY_BASE_DELAY=0.5
